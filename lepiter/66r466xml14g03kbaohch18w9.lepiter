					"time": {
						"__type": "dateAndTime",
						"dateAndTimeString": "2026-03-23T21:07:30.047693+01:00"
					}
				},
				"paragraphStyle": {
					"__type": "textStyle"
				},
				"string": "**Implementación mínima**\n\n`buildSingleSide` usa `BlElement` puro para los paneles con `constraintsDo:` para el sizing, y aplica el color de fondo al propio elemento fila según `status`. Los paneles del lado ausente (`fromSnippet` o `toSnippet` nil) se dejan vacíos."
			},
			{
				"__type": "pharoSnippet",
				"children": {
					"__type": "snippets",
					"items": []
				},
				"createEmail": {
					"__type": "email",
					"emailString": "<unknown>"
				},
				"createTime": {
					"__type": "time",
					"time": {
						"__type": "dateAndTime",
						"dateAndTimeString": "2026-03-23T10:20:33.864753+01:00"
					}
				},
				"editEmail": {
					"__type": "email",
					"emailString": "<unknown>"
				},
				"editTime": {
					"__type": "time",
					"time": {
						"__type": "dateAndTime",
						"dateAndTimeString": "2026-03-23T21:07:30.042615+01:00"
					}
				},
				"uid": {
					"__type": "uid",
					"uidString": "LjiREzNfRzGKVZC+//9srQ=="
				},
				"code": "LpLtSnippetDiffRowElement compile: 'buildSingleSide\n    | leftPanel rightPanel bgColor |\n    bgColor := status = #added\n        ifTrue: [ Color r: 0.9 g: 1.0 b: 0.9 ]\n        ifFalse: [ status = #removed\n            ifTrue: [ Color r: 1.0 g: 0.9 b: 0.9 ]\n            ifFalse: [ Color veryLightGray ] ].\n    self background: bgColor.\n\n    leftPanel := BlElement new.\n    leftPanel id: #leftPanel.\n    leftPanel constraintsDo: [:c | c horizontal matchParent. c vertical fitContent].\n    fromSnippet ifNotNil: [\n        leftPanel addChild: (BrLabel new text: (self snippetTextFor: fromSnippet)) ].\n\n    rightPanel := BlElement new.\n    rightPanel id: #rightPanel.\n    rightPanel constraintsDo: [:c | c horizontal matchParent. c vertical fitContent].\n    toSnippet ifNotNil: [\n        rightPanel addChild: (BrLabel new text: (self snippetTextFor: toSnippet)) ].\n\n    self addChild: leftPanel.\n    self addChild: rightPanel\n' classified: 'building'."
			},
