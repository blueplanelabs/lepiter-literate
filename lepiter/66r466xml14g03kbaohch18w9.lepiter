					"__type": "email",
					"emailString": "<unknown>"
				},
				"createTime": {
					"__type": "time",
					"time": {
						"__type": "dateAndTime",
						"dateAndTimeString": "2026-03-23T09:52:43.842824+01:00"
					}
				},
				"editEmail": {
					"__type": "email",
					"emailString": "<unknown>"
				},
				"editTime": {
					"__type": "time",
					"time": {
						"__type": "dateAndTime",
						"dateAndTimeString": "2026-03-23T09:52:43.842824+01:00"
					}
