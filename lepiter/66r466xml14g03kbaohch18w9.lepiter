					}
				},
				"uid": {
					"__type": "uid",
					"uidString": "43/7sITzQr6H6qd/guLRmw=="
				},
				"code": "LpLtLiveDiffExamples compile: 'examplePageDiffToggleUnchanged\n    <gtExample>\n    <description: ''Tras toggleUnchanged las filas :unchanged tienen visibilidad gone''>\n    <return: #BlScripter>\n    | el scripter |\n    el := self examplePageDiffComputesRows.\n    scripter := BlScripter new element: el.\n    scripter doStep: [ :s |\n        s label: ''Toggle unchanged rows''.\n        s block: [ el toggleUnchanged ] ].\n    scripter checkStep: [ :s |\n        s label: ''Unchanged row (first) has visibility gone''.\n        s value: [ :row | row visibility ]\n            equals: [ BlVisibility gone ].\n        s id: #rowsPane; onChildAt: 1 ].\n    ^ scripter\n' classified: 'examples'."
			},
