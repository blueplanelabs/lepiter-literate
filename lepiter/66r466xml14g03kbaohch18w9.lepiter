				"code": "| fromJson toJson fromPage toPage fromIndex toIndex fromUIDs toUIDs toSet result toIdx |\nfromJson := '{\n  \"__schema\": \"4.1\", \"__type\": \"page\",\n  \"children\": { \"__type\": \"snippets\", \"items\": [\n    { \"__type\": \"textSnippet\", \"string\": \"Introduccion\", \"uid\": { \"__type\": \"uuid\", \"uuid\": \"00000000-0000-0000-0001-000000000001\" }, \"editTime\": { \"__type\": \"time\", \"time\": { \"__type\": \"dateAndTime\", \"dateAndTimeString\": \"2024-01-01T00:00:00+00:00\" } }, \"createTime\": { \"__type\": \"time\", \"time\": { \"__type\": \"dateAndTime\", \"dateAndTimeString\": \"2024-01-01T00:00:00+00:00\" } } },\n    { \"__type\": \"textSnippet\", \"string\": \"Texto original\", \"uid\": { \"__type\": \"uuid\", \"uuid\": \"00000000-0000-0000-0002-000000000001\" }, \"editTime\": { \"__type\": \"time\", \"time\": { \"__type\": \"dateAndTime\", \"dateAndTimeString\": \"2024-01-01T00:00:00+00:00\" } }, \"createTime\": { \"__type\": \"time\", \"time\": { \"__type\": \"dateAndTime\", \"dateAndTimeString\": \"2024-01-01T00:00:00+00:00\" } } },\n    { \"__type\": \"textSnippet\", \"string\": \"Snippet eliminado\", \"uid\": { \"__type\": \"uuid\", \"uuid\": \"00000000-0000-0000-0003-000000000001\" }, \"editTime\": { \"__type\": \"time\", \"time\": { \"__type\": \"dateAndTime\", \"dateAndTimeString\": \"2024-01-01T00:00:00+00:00\" } }, \"createTime\": { \"__type\": \"time\", \"time\": { \"__type\": \"dateAndTime\", \"dateAndTimeString\": \"2024-01-01T00:00:00+00:00\" } } }\n  ] },\n  \"createEmail\": { \"__type\": \"email\", \"emailString\": \"<unknown>\" },\n  \"createTime\": { \"__type\": \"time\", \"time\": { \"__type\": \"dateAndTime\", \"dateAndTimeString\": \"2024-01-01T00:00:00+00:00\" } },\n  \"editEmail\": { \"__type\": \"email\", \"emailString\": \"<unknown>\" },\n  \"editTime\": { \"__type\": \"time\", \"time\": { \"__type\": \"dateAndTime\", \"dateAndTimeString\": \"2024-01-01T00:00:00+00:00\" } },\n  \"pageType\": { \"__type\": \"namedPage\", \"title\": \"From Version\" },\n  \"uid\": { \"__type\": \"uuid\", \"uuid\": \"ffff0000-0000-0000-0000-000000000001\" }\n}'.\ntoJson := '{\n  \"__schema\": \"4.1\", \"__type\": \"page\",\n  \"children\": { \"__type\": \"snippets\", \"items\": [\n    { \"__type\": \"textSnippet\", \"string\": \"Introduccion\", \"uid\": { \"__type\": \"uuid\", \"uuid\": \"00000000-0000-0000-0001-000000000001\" }, \"editTime\": { \"__type\": \"time\", \"time\": { \"__type\": \"dateAndTime\", \"dateAndTimeString\": \"2024-01-01T00:00:00+00:00\" } }, \"createTime\": { \"__type\": \"time\", \"time\": { \"__type\": \"dateAndTime\", \"dateAndTimeString\": \"2024-01-01T00:00:00+00:00\" } } },\n    { \"__type\": \"textSnippet\", \"string\": \"Texto modificado\", \"uid\": { \"__type\": \"uuid\", \"uuid\": \"00000000-0000-0000-0002-000000000001\" }, \"editTime\": { \"__type\": \"time\", \"time\": { \"__type\": \"dateAndTime\", \"dateAndTimeString\": \"2024-01-01T00:00:00+00:00\" } }, \"createTime\": { \"__type\": \"time\", \"time\": { \"__type\": \"dateAndTime\", \"dateAndTimeString\": \"2024-01-01T00:00:00+00:00\" } } },\n    { \"__type\": \"textSnippet\", \"string\": \"Snippet anadido\", \"uid\": { \"__type\": \"uuid\", \"uuid\": \"00000000-0000-0000-0004-000000000001\" }, \"editTime\": { \"__type\": \"time\", \"time\": { \"__type\": \"dateAndTime\", \"dateAndTimeString\": \"2024-01-01T00:00:00+00:00\" } }, \"createTime\": { \"__type\": \"time\", \"time\": { \"__type\": \"dateAndTime\", \"dateAndTimeString\": \"2024-01-01T00:00:00+00:00\" } } }\n  ] },\n  \"createEmail\": { \"__type\": \"email\", \"emailString\": \"<unknown>\" },\n  \"createTime\": { \"__type\": \"time\", \"time\": { \"__type\": \"dateAndTime\", \"dateAndTimeString\": \"2024-01-01T00:00:00+00:00\" } },\n  \"editEmail\": { \"__type\": \"email\", \"emailString\": \"<unknown>\" },\n  \"editTime\": { \"__type\": \"time\", \"time\": { \"__type\": \"dateAndTime\", \"dateAndTimeString\": \"2024-01-01T00:00:00+00:00\" } },\n  \"pageType\": { \"__type\": \"namedPage\", \"title\": \"To Version\" },\n  \"uid\": { \"__type\": \"uuid\", \"uuid\": \"ffff0000-0000-0000-0000-000000000002\" }\n}'.\nfromPage := LeJsonV4 default deserialize: fromJson readStream.\ntoPage := LeJsonV4 default deserialize: toJson readStream.\n\nfromIndex := Dictionary new.\nfromPage children do: [:s | fromIndex at: s uid printString put: s].\ntoIndex := Dictionary new.\ntoPage children do: [:s | toIndex at: s uid printString put: s].\n\nfromUIDs := fromPage children collect: [:s | s uid printString].\ntoUIDs := toPage children collect: [:s | s uid printString].\ntoSet := Set withAll: toUIDs.\nresult := OrderedCollection new.\ntoIdx := 1.\n\nfromUIDs do: [:uid |\n    | from to status |\n    (toSet includes: uid)\n        ifTrue: [\n            [toIdx <= toUIDs size and: [(toUIDs at: toIdx) ~= uid]] whileTrue: [\n                result add: (toUIDs at: toIdx) -> #added.\n                toIdx := toIdx + 1].\n            from := fromIndex at: uid.\n            to := toIndex at: uid.\n            status := from string = to string ifTrue: [#unchanged] ifFalse: [#modified].\n            result add: uid -> status.\n            toIdx := toIdx + 1]\n        ifFalse: [\n            result add: uid -> #removed]].\n[toIdx <= toUIDs size] whileTrue: [\n    result add: (toUIDs at: toIdx) -> #added.\n    toIdx := toIdx + 1].\nresult"
			},
			{
				"__type": "textSnippet",
				"children": {
					"__type": "snippets",
					"items": []
				},
				"paragraphStyle": {
					"__type": "textStyle"
				},
				"string": "Cuando hay varios snippets añadidos consecutivos entre dos comunes, el algoritmo los inserta antes del segundo punto común. Aquí `fromPage` tiene [A, B, C] y `toPage` tiene [A, X, Y, B, C]: X e Y aparecen justo antes de B."
			},
			{
				"__type": "pharoSnippet",
				"children": {
					"__type": "snippets",
					"items": []
				},
				"code": "| fromUIDs toUIDs toSet result toIdx |\nfromUIDs := #('A' 'B' 'C').\ntoUIDs   := #('A' 'X' 'Y' 'B' 'C').\ntoSet := Set withAll: toUIDs.\nresult := OrderedCollection new.\ntoIdx := 1.\nfromUIDs do: [:uid |\n    | status |\n    (toSet includes: uid)\n        ifTrue: [\n            [toIdx <= toUIDs size and: [(toUIDs at: toIdx) ~= uid]] whileTrue: [\n                result add: (toUIDs at: toIdx) -> #added.\n                toIdx := toIdx + 1].\n            status := #unchanged.\n            result add: uid -> status.\n            toIdx := toIdx + 1]\n        ifFalse: [\n            result add: uid -> #removed]].\n[toIdx <= toUIDs size] whileTrue: [\n    result add: (toUIDs at: toIdx) -> #added.\n    toIdx := toIdx + 1].\nresult"
			},
			{
				"__type": "textSnippet",
				"children": {
					"__type": "snippets",
					"items": []
				},
				"paragraphStyle": {
					"__type": "textStyle"
				},
				"string": "Cuando hay varios snippets eliminados consecutivos, aparecen en su posición original. Aquí `fromPage` tiene [A, B, C, D] y `toPage` tiene [A, D, X]: B y C aparecen entre A y D, y X al final."
			},
			{
				"__type": "pharoSnippet",
				"children": {
					"__type": "snippets",
					"items": []
				},
				"code": "| fromUIDs toUIDs toSet result toIdx |\nfromUIDs := #('A' 'B' 'C' 'D').\ntoUIDs   := #('A' 'D' 'X').\ntoSet := Set withAll: toUIDs.\nresult := OrderedCollection new.\ntoIdx := 1.\nfromUIDs do: [:uid |\n    | status |\n    (toSet includes: uid)\n        ifTrue: [\n            [toIdx <= toUIDs size and: [(toUIDs at: toIdx) ~= uid]] whileTrue: [\n                result add: (toUIDs at: toIdx) -> #added.\n                toIdx := toIdx + 1].\n            status := #unchanged.\n            result add: uid -> status.\n            toIdx := toIdx + 1]\n        ifFalse: [\n            result add: uid -> #removed]].\n[toIdx <= toUIDs size] whileTrue: [\n    result add: (toUIDs at: toIdx) -> #added.\n    toIdx := toIdx + 1].\nresult"
			},
