				"code": "LpLtLiveDiffExamples compile: 'exampleModifiedRow\n    <gtExample>\n    <description: ''Una fila construida con dos snippets de texto diferente tiene status #modified''>\n    <return: #LpLtSnippetDiffRowElement>\n    | from to row |\n    from := LeTextSnippet new updateString: ''Texto original''.\n    to := LeTextSnippet new updateString: ''Texto modificado''.\n    row := LpLtSnippetDiffRowElement from: from to: to status: #modified.\n    self assert: row status equals: #modified.\n    self assert: row fromSnippet notNil.\n    self assert: row toSnippet notNil.\n    ^ row\n' classified: 'examples'."
			},
