					}
				},
				"uid": {
					"__type": "uid",
					"uidString": "Bwj4vOOkRz6cl2TMSTa31A=="
				},
				"code": "LpLtLiveDiffExamples compile: 'exampleAddedRow\n    <gtExample>\n    <description: ''Una fila con fromSnippet nil tiene status #added''>\n    <return: #LpLtSnippetDiffRowElement>\n    | to row |\n    to := LeTextSnippet new updateString: ''Snippet anadido''.\n    row := LpLtSnippetDiffRowElement from: nil to: to status: #added.\n    self assert: row status equals: #added.\n    self assert: row fromSnippet isNil.\n    ^ row\n' classified: 'examples'.\n\nLpLtLiveDiffExamples compile: 'exampleRemovedRow\n    <gtExample>\n    <description: ''Una fila con toSnippet nil tiene status #removed''>\n    <return: #LpLtSnippetDiffRowElement>\n    | from row |\n    from := LeTextSnippet new updateString: ''Snippet eliminado''.\n    row := LpLtSnippetDiffRowElement from: from to: nil status: #removed.\n    self assert: row status equals: #removed.\n    self assert: row toSnippet isNil.\n    ^ row\n' classified: 'examples'."
			},
