				"code": "LpLtSnippetDiffRowElement class compile: 'from: aFromSnippet to: aToSnippet status: aStatus\n    | row |\n    row := self new.\n    row pvtFromSnippet: aFromSnippet.\n    row pvtToSnippet: aToSnippet.\n    row pvtStatus: aStatus.\n    ^ row\n' classified: 'instance creation'.\n\nLpLtSnippetDiffRowElement compile: 'status\n    ^ status\n' classified: 'accessing'.\n\nLpLtSnippetDiffRowElement compile: 'fromSnippet\n    ^ fromSnippet\n' classified: 'accessing'.\n\nLpLtSnippetDiffRowElement compile: 'toSnippet\n    ^ toSnippet\n' classified: 'accessing'.\n\nLpLtSnippetDiffRowElement compile: 'pvtFromSnippet: aSnippet\n    fromSnippet := aSnippet\n' classified: 'private'.\n\nLpLtSnippetDiffRowElement compile: 'pvtToSnippet: aSnippet\n    toSnippet := aSnippet\n' classified: 'private'.\n\nLpLtSnippetDiffRowElement compile: 'pvtStatus: aStatus\n    status := aStatus\n' classified: 'private'."
			},
