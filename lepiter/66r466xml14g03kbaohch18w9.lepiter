				"code": "LpLtPageLiveDiffElement compile: 'fromContents: aString\n    fromPage := LeJsonV4 default deserialize: aString readStream\n' classified: 'accessing'.\n\nLpLtPageLiveDiffElement compile: 'toContents: aString\n    toPage := LeJsonV4 default deserialize: aString readStream.\n    self buildDiff\n' classified: 'accessing'.\n\nLpLtPageLiveDiffElement compile: 'diffRows\n    ^ diffRows\n' classified: 'accessing'.\n\nLpLtPageLiveDiffElement compile: 'snippetTextFor: aSnippet\n    (aSnippet isKindOf: LeTextualSnippet) ifTrue: [ ^ aSnippet string ].\n    (aSnippet isKindOf: LeCodeSnippet) ifTrue: [ ^ aSnippet code ].\n    ^ aSnippet printString\n' classified: 'private'.\n\nLpLtPageLiveDiffElement compile: 'computeDiffRows\n    | fromIndex toIndex fromUIDs toUIDs toSet result toIdx |\n    fromIndex := Dictionary new.\n    fromPage children do: [:s | fromIndex at: s uid printString put: s].\n    toIndex := Dictionary new.\n    toPage children do: [:s | toIndex at: s uid printString put: s].\n    fromUIDs := fromPage children collect: [:s | s uid printString].\n    toUIDs := toPage children collect: [:s | s uid printString].\n    toSet := Set withAll: toUIDs.\n    result := OrderedCollection new.\n    toIdx := 1.\n    fromUIDs do: [:uid |\n        | from to status |\n        (toSet includes: uid)\n            ifTrue: [\n                [toIdx <= toUIDs size and: [(toUIDs at: toIdx) ~= uid]] whileTrue: [\n                    | addedSnippet |\n                    addedSnippet := toIndex at: (toUIDs at: toIdx).\n                    result add: (LpLtSnippetDiffRowElement from: nil to: addedSnippet status: #added).\n                    toIdx := toIdx + 1].\n                from := fromIndex at: uid.\n                to := toIndex at: uid.\n                status := (self snippetTextFor: from) = (self snippetTextFor: to)\n                    ifTrue: [#unchanged] ifFalse: [#modified].\n                result add: (LpLtSnippetDiffRowElement from: from to: to status: status).\n                toIdx := toIdx + 1]\n            ifFalse: [\n                from := fromIndex at: uid.\n                result add: (LpLtSnippetDiffRowElement from: from to: nil status: #removed)]].\n    [toIdx <= toUIDs size] whileTrue: [\n        | addedSnippet |\n        addedSnippet := toIndex at: (toUIDs at: toIdx).\n        result add: (LpLtSnippetDiffRowElement from: nil to: addedSnippet status: #added).\n        toIdx := toIdx + 1].\n    ^ result\n' classified: 'private'.\n\nLpLtPageLiveDiffElement compile: 'buildDiff\n    diffRows := self computeDiffRows\n' classified: 'building'."
			},
